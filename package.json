{
  "name": "match_mind",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm run dev --workspace=apps/api",
    "web": "npm run dev --workspace=apps/web",
    "dev": "concurrently \"npm run api\" \"npm run web\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
